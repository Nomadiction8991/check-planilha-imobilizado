# === PHP project ignore rules ===
# Dependencies (installed via Composer)
/vendor/

# Environment / secrets
.env

# IDE / editor
.vscode/
.idea/
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Caches / logs
*.log
cache/
/storage/*
/storage/.gitkeep
/storage/importacao/
/storage/importacao/.gitkeep
/storage/logs/
/storage/logs/.gitkeep
/storage/tmp/
/storage/tmp/.gitkeep
/tmp/

# Node (if ever used)
/node_modules/

# Misc
*.bak
*.swp

napkin.md
